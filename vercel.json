{
  "version": 2,
  "builds": [
    {
      "src": "vercel/api/mistral.js",
      "use": "@vercel/node"
    },
    {
      "src": "app.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/mistral",
      "dest": "vercel/api/mistral.js"
    },
    {
      "src": "/",
      "dest": "app.html"
    }
  ],
  "env": {
    "MISTRAL_API_KEY": "@mistral_api_key"
  }
}
